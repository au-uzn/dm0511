{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A tea menu item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "englishName": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "sizes": {
          "type": "object",
          "properties": {
            "M": { "type": "number" },
            "L": { "type": "number" }
          }
        },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "category", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "size": { "type": "string" },
              "sweetness": { "type": "string" },
              "ice": { "type": "string" },
              "toppings": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "customerName": { "type": "string" }
      },
      "required": ["items", "total", "status", "createdAt"]
    },
    "Config": {
      "title": "Config",
      "description": "System configuration",
      "type": "object",
      "properties": {
        "adminPasswordHash": { "type": "string" },
        "isSetup": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of tea products"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "config": {
      "schema": "Config",
      "description": "System configuration document"
    }
  }
}
