rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Products: Public read, Admin write (requires password check in app, hard to secure in rules without auth)
    // For this specific request, we will allow read for everyone.
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Only manageable through Firebase Console or if we had a secure way
    }

    // Orders: Public create, Admin read/update
    match /orders/{orderId} {
      allow create: if isValidId(orderId) 
        && incoming().status == 'pending'
        && incoming().items is list
        && incoming().total is number;
      allow read, update, delete: if false; // Admin view only through some bypass or if we use auth
    }

    // Config: Special handling for setup
    match /config/{configId} {
      allow read: if true;
      allow create: if configId == 'system' && !exists(/databases/$(database)/documents/config/system);
      allow update: if false; // Locked after setup
    }
  }
}
